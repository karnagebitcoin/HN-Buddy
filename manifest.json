{
  "manifest_version": 3,
  "name": "HN Buddy",
  "description": "Sleek Hacker News feed and discussion widget for your browser toolbar.",
  "version": "0.1.0",
  "action": {
    "default_title": "HN Buddy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "64": "icons/64.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://news.ycombinator.com/*",
    "https://hacker-news.firebaseio.com/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https:;"
  }
}
